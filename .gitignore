# .env
.env

# keys & secrets (defense in depth — none should ever exist in the tree)
*.pem
*.key
*.secret
.dev.vars*
# block new witness files anywhere; committed contract test fixtures stay tracked
**/Prover.toml

# circuits
circuits/target/
target/
node_modules/

# poc
poc/node_modules
poc/dist
poc/public/wasm/*.wasm
poc/public/wasm/*.wasm.gz
poc/public/circuits/zarf.json

# contracts
contracts/soroban/**/target/
test_snapshots/

# notes, backlogs & ai scratch — but committed documentation is allowed:
# docs/ (ADRs, runbooks), package READMEs, and the governance files below.
*.md
!/README.md
!**/README.md
!/docs/**
!/CLAUDE.md
!/SECURITY.md
!/CONTRIBUTING.md
# internal audit/business doc — kept local, not part of the public codebase.
# Must come AFTER `!/docs/**` so this re-ignore wins by last-match.
/docs/proposal_audit.md
_backlogs/
reports/
.DS_Store
*.csv
!whitelist_sample.csv
*.txt
test/*.dev

# Agents & Tools
.geminiignore
.agent/
.agents/
.gemini/
.claude/
.claude-tmp/
.kiro/
.cursor/

#plans
plans/
