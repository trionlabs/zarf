# Google OAuth Client ID
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

# Stellar / Soroban
VITE_STELLAR_RPC_URL=
VITE_STELLAR_HORIZON_URL=
VITE_STELLAR_NETWORK_PASSPHRASE=
VITE_STELLAR_NETWORK_NAME=
VITE_STELLAR_FACTORY_ADDRESS=
VITE_STELLAR_VESTING_ADDRESS=
VITE_STELLAR_JWK_REGISTRY_ADDRESS=
VITE_STELLAR_VERIFIER_ADDRESS=
VITE_STELLAR_TOKEN_ADDRESS=
VITE_STELLAR_NATIVE_TOKEN_ADDRESS=
VITE_STELLAR_EXPLORER_URL=

# Pinning proxy
VITE_PIN_PROXY_URL=

# Shared read indexer/proxy
VITE_INDEXER_URL=

# Indexer worker Stellar config
# (Read caching uses the Cloudflare Cache API with hardcoded per-endpoint
# TTLs in web/apps/indexer/src/index.ts — no KV namespace or TTL env vars.)
STELLAR_TESTNET_RPC_URL=
STELLAR_TESTNET_FACTORY_ADDRESS=
STELLAR_TESTNET_NETWORK_PASSPHRASE=
STELLAR_MAINNET_RPC_URL=
STELLAR_MAINNET_FACTORY_ADDRESS=
STELLAR_MAINNET_NETWORK_PASSPHRASE=
