root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Matches web/.prettierrc (4-space, single quotes) for the web monorepo.
[*.{ts,js,svelte,mjs,cjs,css}]
indent_style = space
indent_size = 4

# .prettierrc overrides json/md/yml to 2-space.
[*.{json,jsonc,yml,yaml,md}]
indent_style = space
indent_size = 2

[*.rs]
indent_style = space
indent_size = 4

[*.nr]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
