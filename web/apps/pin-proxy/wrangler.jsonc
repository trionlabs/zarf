{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "zarf-pin-proxy",
    "account_id": "97f6beae024e619ebd9faedf1c00b9e8",
    "main": "src/index.ts",
    "compatibility_date": "2025-01-15",
    "vars": {
        "ALLOWED_ORIGINS": "http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,https://create.zarf.to,https://claim.zarf.to,https://airdrop.zarf.to",
        "MAX_BODY_BYTES": "1048576",
    },
    "observability": {
        "enabled": true,
    },
    "routes": [
        {
            "pattern": "pin.zarf.to",
            "custom_domain": true,
        },
    ],
    // Set the Pinata JWT as a secret (NOT a var):
    //   wrangler secret put PINATA_JWT
    //
    // For production, override ALLOWED_ORIGINS via dashboard or wrangler --var.
    // CORS now FAILS CLOSED (no '*' fallback), so an override must list the FULL
    // set — narrowing to one origin hard-blocks the rest:
    //   --var ALLOWED_ORIGINS:"https://create.zarf.to,https://claim.zarf.to,https://airdrop.zarf.to"
}
