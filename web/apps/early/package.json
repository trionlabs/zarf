{
  "name": "@zarf/early",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "deploy": "vite build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply zarf-early --local",
    "db:migrate:remote": "wrangler d1 migrations apply zarf-early --remote"
  },
  "dependencies": {
    "@zarf/core": "workspace:*",
    "@zarf/ui": "workspace:*",
    "arctic": "2.3.4",
    "lucide-svelte": "^0.563.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260527.1",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.3.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "wrangler": "^4.107.0"
  }
}
