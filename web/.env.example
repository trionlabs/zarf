# --------------------------------------------------------------------------
# Zarf web monorepo — environment template
# --------------------------------------------------------------------------
# Vite loads this file via `envDir: '../..'` in apps/*/vite.config.ts
# (resolved from web/apps/{app}/ this points at this directory).
# Copy to `web/.env` and fill in real values. Never commit `.env`.
#
# Build requirements (apps that touch the Stellar config will THROW at
# SSR time unless these are populated — see coreInit.ts):
#   1. VITE_STELLAR_TESTNET_RPC_URL          (defaulted below to public RPC)
#   2. VITE_STELLAR_TESTNET_FACTORY_ADDRESS  (REQUIRED — your deployed factory)
#
# The landing app doesn't read Stellar config and builds with this template
# unmodified. The claim and create apps will not build until at least the
# testnet factory address is filled in.
# --------------------------------------------------------------------------

# Google OAuth (claim flow uses this for OIDC id_token issuance).
# Create credentials at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

# Default Stellar network when no `localStorage` override is set.
# One of: testnet | mainnet
VITE_STELLAR_DEFAULT_NETWORK=testnet

# --------------------------------------------------------------------------
# Stellar — testnet
# --------------------------------------------------------------------------
# RPC + FACTORY_ADDRESS are required for testnet to load; everything else
# falls back to Horizon defaults / on-chain discovery.
VITE_STELLAR_TESTNET_RPC_URL=https://soroban-testnet.stellar.org
VITE_STELLAR_TESTNET_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_STELLAR_TESTNET_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_STELLAR_TESTNET_NETWORK_NAME=Testnet
# REQUIRED for claim and create builds. Get this from your deployed factory.
VITE_STELLAR_TESTNET_FACTORY_ADDRESS=
VITE_STELLAR_TESTNET_VESTING_ADDRESS=
VITE_STELLAR_TESTNET_JWK_REGISTRY_ADDRESS=
VITE_STELLAR_TESTNET_VERIFIER_ADDRESS=
VITE_STELLAR_TESTNET_TOKEN_ADDRESS=
VITE_STELLAR_TESTNET_EXPLORER_URL=https://stellar.expert/explorer/testnet

# --------------------------------------------------------------------------
# Stellar — mainnet (optional; omit to ship testnet-only)
# --------------------------------------------------------------------------
VITE_STELLAR_MAINNET_RPC_URL=
VITE_STELLAR_MAINNET_HORIZON_URL=https://horizon.stellar.org
VITE_STELLAR_MAINNET_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
VITE_STELLAR_MAINNET_NETWORK_NAME=Mainnet
VITE_STELLAR_MAINNET_FACTORY_ADDRESS=
VITE_STELLAR_MAINNET_VESTING_ADDRESS=
VITE_STELLAR_MAINNET_JWK_REGISTRY_ADDRESS=
VITE_STELLAR_MAINNET_VERIFIER_ADDRESS=
VITE_STELLAR_MAINNET_TOKEN_ADDRESS=
VITE_STELLAR_MAINNET_EXPLORER_URL=https://stellar.expert/explorer/public

# --------------------------------------------------------------------------
# Legacy single-network keys (still read as a fallback for testnet only).
# Prefer the VITE_STELLAR_TESTNET_*/MAINNET_* split above for new setups.
# --------------------------------------------------------------------------
# VITE_STELLAR_RPC_URL=
# VITE_STELLAR_HORIZON_URL=
# VITE_STELLAR_NETWORK_PASSPHRASE=
# VITE_STELLAR_NETWORK_NAME=
# VITE_STELLAR_FACTORY_ADDRESS=
# VITE_STELLAR_VESTING_ADDRESS=
# VITE_STELLAR_JWK_REGISTRY_ADDRESS=
# VITE_STELLAR_VERIFIER_ADDRESS=
# VITE_STELLAR_TOKEN_ADDRESS=
# VITE_STELLAR_EXPLORER_URL=

# --------------------------------------------------------------------------
# Off-chain services
# --------------------------------------------------------------------------
# IPFS pinning proxy (required for create flow's `pinClaimList` calls).
VITE_PIN_PROXY_URL=

# Shared read indexer (optional; falls back to direct RPC reads if unset).
VITE_INDEXER_URL=
